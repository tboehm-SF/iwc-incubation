                  <tr><td>Builder Type</td><td>Visual Builder</td></tr>
                  <tr><td>Starting Object</td><td>Reservation</td></tr>
                  <tr><td>Related Object (Join)</td><td>Unified Individual (via ccid, N:1)</td></tr>
                  <tr><td>Measure 1</td><td>COUNT(Reservation_Id) = "Lifetime Reservations"</td></tr>
                  <tr><td>Measure 2</td><td>SUM(Total_Price) = "Lifetime Value"</td></tr>
