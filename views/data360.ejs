<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Data 360 Track' }) %>
<body>
  <%- include('partials/header') %>

  <style>
    /* Screenshot Gallery */
    .screenshot-gallery { display: flex; flex-wrap: wrap; gap: 12px; margin: 16px 0; }
    .screenshot-thumb {
      position: relative; border-radius: 12px; overflow: hidden;
      border: 1px solid var(--gray-200); cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      flex: 1 1 260px; max-width: 100%;
    }
    .screenshot-thumb:hover { border-color: var(--iwc-gold); box-shadow: 0 8px 30px rgba(196,169,98,0.2); transform: translateY(-2px); }
    .screenshot-thumb img { display: block; width: 100%; height: auto; transition: transform 0.3s ease; }
    .screenshot-thumb:hover img { transform: scale(1.02); }
    .screenshot-caption {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(transparent, rgba(12,27,42,0.85));
      color: white; padding: 24px 12px 10px; font-size: 12px; font-weight: 500;
      opacity: 0; transition: opacity 0.3s ease;
    }
    .screenshot-thumb:hover .screenshot-caption { opacity: 1; }
    .screenshot-expand-icon {
      position: absolute; top: 8px; right: 8px; width: 28px; height: 28px;
      background: rgba(12,27,42,0.7); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s ease;
    }
    .screenshot-thumb:hover .screenshot-expand-icon { opacity: 1; }

    /* Lightbox */
    .screenshot-lightbox {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(5,13,23,0.92); backdrop-filter: blur(8px);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.3s ease; padding: 32px;
    }
    .screenshot-lightbox.active { opacity: 1; pointer-events: auto; }
    .screenshot-lightbox img {
      max-width: 95vw; max-height: 90vh; border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      transform: scale(0.9); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .screenshot-lightbox.active img { transform: scale(1); }
    .screenshot-lightbox-caption {
      position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
      background: rgba(12,27,42,0.9); color: white; padding: 8px 20px;
      border-radius: 20px; font-size: 13px; font-weight: 500; white-space: nowrap;
    }
    .screenshot-lightbox-close {
      position: absolute; top: 20px; right: 24px; width: 36px; height: 36px;
      background: rgba(255,255,255,0.15); border: none; border-radius: 50%;
      color: white; font-size: 20px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; transition: background 0.2s;
    }
    .screenshot-lightbox-close:hover { background: rgba(255,255,255,0.3); }

    /* Credential Tables */
    .credential-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .credential-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: var(--iwc-gold-dark); border-bottom: 2px solid rgba(196,169,98,0.3); }
    .credential-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--gray-200); color: var(--gray-700); vertical-align: top; }
    .credential-table code { font-family: 'SF Mono', monospace; background: rgba(12,27,42,0.06); padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; color: var(--iwc-navy); }

    /* Private Key Display */
    .private-key-container { position: relative; }
    .private-key-display {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.65rem;
      line-height: 1.4;
      background: rgba(12, 27, 42, 0.06);
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      padding: 0.75rem;
      white-space: pre-wrap;
      word-break: break-all;
      color: var(--iwc-navy);
      max-height: 180px;
      overflow-y: auto;
      margin: 0 0 0.5rem 0;
    }
    .copy-key-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      color: var(--iwc-navy);
      background: rgba(196, 169, 98, 0.15);
      border: 1px solid rgba(196, 169, 98, 0.4);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .copy-key-btn:hover {
      background: rgba(196, 169, 98, 0.25);
      border-color: rgba(196, 169, 98, 0.6);
    }
    .copy-key-btn:active { transform: scale(0.95); }
    .copy-key-confirmation {
      display: inline-block;
      margin-left: 0.5rem;
      font-size: 0.75rem;
      color: #2E844A;
      font-weight: 600;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .copy-key-confirmation--visible { opacity: 1; }

    /* Inline key display (single-line keys like AWS) */
    .private-key-inline {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .private-key-inline code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.8rem;
      background: rgba(12, 27, 42, 0.06);
      padding: 4px 8px;
      border-radius: 4px;
      color: var(--iwc-navy);
      user-select: all;
    }
    .copy-key-btn--inline {
      padding: 0.25rem 0.5rem;
      font-size: 0.7rem;
    }

    /* Mapping Tables */
    .mapping-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; border-radius: 12px; overflow: hidden; border: 1px solid var(--gray-200); }
    .mapping-table th { padding: 0.6rem 0.8rem; background: var(--iwc-navy); color: var(--iwc-gold); text-align: left; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .mapping-table td { padding: 0.6rem 0.8rem; border-bottom: 1px solid var(--gray-100); color: var(--gray-700); }
    .mapping-table tr:nth-child(even) td { background: var(--gray-50); }
    .mapping-table .mono { font-family: 'SF Mono', monospace; font-size: 0.75rem; color: var(--iwc-navy); }

    /* Step Cards (detailed) */
    .step-card-detailed { border: 1px solid var(--gray-200); border-radius: 12px; padding: 1.25rem; margin-bottom: 0.75rem; transition: all 0.2s ease; background: var(--gray-50); }
    .step-card-detailed:hover { border-color: var(--iwc-gold); }
    .step-card-detailed__number { width: 32px; height: 32px; background: linear-gradient(135deg, #C4A962, #A68B4B); color: #0C1B2A; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0; }
    .step-card-detailed__title { font-weight: 600; font-size: 0.9rem; color: var(--gray-800); margin-bottom: 0.25rem; }
    .step-card-detailed__desc { font-size: 0.85rem; color: var(--gray-600); line-height: 1.6; }

    /* Section Headers */
    .section-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; margin-top: 2rem; }
    .section-header__badge { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.7rem; font-weight: 700; color: var(--iwc-gold-dark); background: rgba(196,169,98,0.12); padding: 0.25rem 0.75rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em; }
    .section-header__title { font-size: 1.1rem; font-weight: 700; color: var(--gray-800); }
    .section-divider-gold { height: 2px; background: linear-gradient(90deg, var(--iwc-gold), rgba(196,169,98,0.3), transparent); margin: 2rem 0 1.5rem; border-radius: 1px; }

    /* Info/Tip/Warning boxes within modules */
    .module-callout { display: flex; gap: 0.75rem; padding: 1rem; border-radius: 10px; margin: 1rem 0; font-size: 0.85rem; line-height: 1.5; }
    .module-callout--info { background: rgba(196,169,98,0.08); border: 1px solid rgba(196,169,98,0.25); color: var(--gray-700); }
    .module-callout--tip { background: var(--green-light); border: 1px solid rgba(46,132,74,0.3); color: #166534; }
    .module-callout--warning { background: var(--orange-light); border: 1px solid rgba(221,122,1,0.3); color: #92400e; }
    .module-callout__icon { width: 24px; height: 24px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .module-callout--info .module-callout__icon { background: rgba(196,169,98,0.2); }
    .module-callout--tip .module-callout__icon { background: rgba(46,132,74,0.15); }
    .module-callout--warning .module-callout__icon { background: rgba(221,122,1,0.15); }
  </style>

  <!-- ============================================== -->
  <!-- TRACK HERO                                     -->
  <!-- ============================================== -->
  <section class="track-hero-v2">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator">/</span>
        <a href="/" class="breadcrumb__link">Tracks</a>
        <span class="breadcrumb__separator">/</span>
        <span class="breadcrumb__current">Data 360</span>
      </nav>
      <div class="track-hero-v2__badge">
        <i class="ph ph-database"></i>
        Data 360 Deep-Dive
      </div>
      <h1 class="track-hero-v2__title">Data 360 Track</h1>
      <p class="track-hero-v2__subtitle">Build a complete data unification solution for Coral Cloud Resorts using Data 360. Ingest data from CRM and external sources, resolve identities, create calculated insights, build segments, and activate audiences.</p>
      <div class="track-hero-v2__stats">
        <div class="track-hero-v2__stat">
          <span class="track-hero-v2__stat-value">8</span>
          <span class="track-hero-v2__stat-label">Modules</span>
        </div>
        <div class="track-hero-v2__stat">
          <span class="track-hero-v2__stat-value">~90</span>
          <span class="track-hero-v2__stat-label">Steps</span>
        </div>
        <div class="track-hero-v2__stat">
          <span class="track-hero-v2__stat-value">~4h</span>
          <span class="track-hero-v2__stat-label">Duration</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- STICKY PROGRESS BAR                            -->
  <!-- ============================================== -->
  <div class="progress-section-v2" id="progress-section-v2">
    <div class="container">
      <div class="progress-section-v2__inner">
        <span class="progress-section-v2__label">Your Progress</span>
        <div class="progress-section-v2__bar">
          <div class="progress-section-v2__fill" id="overall-progress-main"></div>
        </div>
        <span class="progress-section-v2__percent" id="overall-progress-text">0%</span>
      </div>
    </div>
  </div>

  <!-- ============================================== -->
  <!-- DATA 360 TRACK MODULES                         -->
  <!-- ============================================== -->
  <section class="section marketing-track-section" id="data360-track" style="padding-top: 40px;">
    <div class="container">

      <!-- ════════════════════════════════════════════ -->
      <!-- MODULE 1: Data 360 Setup                    -->
      <!-- ════════════════════════════════════════════ -->
      <div class="module-v2 animate-on-scroll" data-module="module-1">
        <div class="module-v2__card">
          <div class="module-v2__header" role="button" aria-expanded="false">
            <span class="module-v2__number">1</span>
            <div class="module-v2__info">
              <h3 class="module-v2__title">Data 360 Setup</h3>
              <p class="module-v2__subtitle">CRM Streams, S3 Connector, Snowflake, Identity Resolution</p>
            </div>
            <div class="module-v2__meta">
              <span class="module-v2__step-count">0 / 20</span>
            </div>
            <span class="module-v2__chevron"><i class="ph ph-caret-down"></i></span>
          </div>
          <div class="module-v2__content">
            <div class="module-v2__body">
              <p class="module-v2__description">Welcome to the Data 360 Track! In this module, you will set up the foundational data connections for <strong>Coral Cloud Resorts</strong> — a luxury resort chain using Data 360 to unify guest data from multiple sources. You will configure CRM data streams, external connectors (Amazon S3 and Snowflake), and identity resolution rules.</p>

              <div class="callout-v2 callout-v2--info">
                <span class="callout-v2__icon"><i class="ph ph-info"></i></span>
                <div><strong>Scenario:</strong> Coral Cloud Resorts wants to unify guest data from their CRM, booking system (S3), and loyalty program (Snowflake) to create a 360-degree view of each guest and personalize their experience.</div>
              </div>

              <!-- What You'll Learn -->
              <div class="module-callout module-callout--info">
                <span class="module-callout__icon"><i class="ph ph-lightbulb" style="color:#C4A962"></i></span>
                <div>
                  <strong>What You'll Learn:</strong><br>
                  • Install the workshop Data Kit and set up your SDO org<br>
                  • Create Data Streams from Salesforce CRM objects and map them to standard DMOs<br>
                  • Connect Amazon S3 and ingest external guest CSV data<br>
                  • Set up the Snowflake Zero-Copy connector for hotel reservation data<br>
                  • Create a custom Reservation DMO with relationships<br>
                  • Configure Identity Resolution with exact and fuzzy match rules
                </div>
              </div>

              <!-- EXERCISE 1a: CRM Data Streams -->
              <div class="section-divider-gold"></div>
              <div class="section-header">
                <span class="section-header__badge">Exercise 1a</span>
                <span class="section-header__title">CRM Data Streams</span>
              </div>
              <p style="color:var(--gray-600); font-size:0.85rem; margin-bottom:1rem;">Pull data directly from Salesforce CRM. These streams ingest Account, Contact, and Lead into Data 360, creating Data Lake Objects (DLOs) that map to standard Data Model Objects (DMOs).</p>

              <!-- Screenshots: CRM Data Streams -->
              <div class="screenshot-gallery">
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/data-streams-empty.png','Data Streams — Starting Point')"><img src="/assets/images/screenshots/data-streams-empty.png" alt="Data Streams starting point" loading="lazy"><div class="screenshot-caption">Data Streams — Starting Point</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-new-data-stream-dialog.png','New Data Stream Dialog')"><img src="/assets/images/screenshots/ex1a-new-data-stream-dialog.png" alt="New Data Stream dialog" loading="lazy"><div class="screenshot-caption">New Data Stream Dialog</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-select-coral-cloud-bundle.png','Select Coral Cloud Bundle')"><img src="/assets/images/screenshots/ex1a-select-coral-cloud-bundle.png" alt="Select Coral Cloud bundle" loading="lazy"><div class="screenshot-caption">Select Coral Cloud Bundle</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-contact-fields-selection.png','Contact Fields Selection')"><img src="/assets/images/screenshots/ex1a-contact-fields-selection.png" alt="Contact fields selection" loading="lazy"><div class="screenshot-caption">Contact Fields Selection</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-deploy-contact-stream.png','Deploy Contact Stream')"><img src="/assets/images/screenshots/ex1a-deploy-contact-stream.png" alt="Deploy Contact stream" loading="lazy"><div class="screenshot-caption">Deploy Contact Stream</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-contact-stream-deployed.png','Stream Deployed Successfully')"><img src="/assets/images/screenshots/ex1a-contact-stream-deployed.png" alt="Contact stream deployed" loading="lazy"><div class="screenshot-caption">Stream Deployed</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1a-data-streams-list.png','Data Streams List')"><img src="/assets/images/screenshots/ex1a-data-streams-list.png" alt="Data Streams list" loading="lazy"><div class="screenshot-caption">Data Streams List</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
              </div>

              <!-- DMO Mapping Tables -->
              <div class="section-header" style="margin-top:1.5rem">
                <span class="section-header__title">DMO Attribute Mapping</span>
              </div>
              <p style="color:var(--gray-500); font-size:0.8rem; margin-bottom:0.75rem;">Contact → Individual DMO</p>
              <table class="mapping-table">
                <thead><tr><th>Source Field (CRM)</th><th>DMO Field (Individual)</th><th>Notes</th></tr></thead>
                <tbody>
                  <tr><td class="mono">FirstName</td><td class="mono">First Name</td><td>Used in Identity Resolution</td></tr>
                  <tr><td class="mono">LastName</td><td class="mono">Last Name</td><td>Used in Identity Resolution</td></tr>
                  <tr><td class="mono">Birthdate</td><td class="mono">Birth Date</td><td>Optional demographic</td></tr>
                  <tr><td class="mono">Id</td><td class="mono">Individual Id</td><td>Primary key</td></tr>
                </tbody>
              </table>
              <p style="color:var(--gray-500); font-size:0.8rem; margin:0.75rem 0;">Contact → Contact Point Email DMO</p>
              <table class="mapping-table">
                <thead><tr><th>Source Field</th><th>DMO Field</th><th>Notes</th></tr></thead>
                <tbody>
                  <tr><td class="mono">Email</td><td class="mono">Email Address</td><td>Used in Identity Resolution</td></tr>
                  <tr><td class="mono">Id</td><td class="mono">Contact Point Email Id</td><td>Primary key</td></tr>
                  <tr><td class="mono">Id</td><td class="mono">Party Id</td><td>Links to Individual</td></tr>
                </tbody>
              </table>

              <!-- EXERCISE 1b: Amazon S3 -->
              <div class="section-divider-gold"></div>
              <div class="section-header">
                <span class="section-header__badge">Exercise 1b</span>
                <span class="section-header__title">Amazon S3 Data Ingestion</span>
              </div>
              <p style="color:var(--gray-600); font-size:0.85rem; margin-bottom:1rem;">Connect to S3 and ingest the Coral_Clouds_Guests.csv containing guest profiles.</p>

              <p style="color:var(--iwc-gold-dark); font-size:0.8rem; font-weight:600; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:0.03em;">S3 CONNECTION CREDENTIALS</p>
              <table class="credential-table">
                <thead><tr><th>Field</th><th>Value</th></tr></thead>
                <tbody>
                  <tr><td>Connection</td><td><code>Coral Cloud Resort S3 Connection</code></td></tr>
                  <tr><td>Access Key</td><td>
                    <div class="private-key-inline">
                      <code id="aws-access-key">AKIA47CRZ7L5P7VBV3LD</code>
                      <button class="copy-key-btn copy-key-btn--inline" onclick="copyPrivateKey('aws-access-key')" title="Copy">
                        <i class="ph ph-copy"></i>
                      </button>
                      <span class="copy-key-confirmation" id="copied-aws-access-key">Copied!</span>
                    </div>
                  </td></tr>
                  <tr><td>Secret Access Key</td><td>
                    <div class="private-key-inline">
                      <code id="aws-secret-key">PIVzypT/xl7EG9dwbv2tMOqoHpiPBV9AeEvZFvd9</code>
                      <button class="copy-key-btn copy-key-btn--inline" onclick="copyPrivateKey('aws-secret-key')" title="Copy">
                        <i class="ph ph-copy"></i>
                      </button>
                      <span class="copy-key-confirmation" id="copied-aws-secret-key">Copied!</span>
                    </div>
                  </td></tr>
                  <tr><td>File Type</td><td><code>CSV</code></td></tr>
                  <tr><td>Bucket Name</td><td><code>coral-cloud</code></td></tr>
                  <tr><td>File Name</td><td><code>Coral_Clouds_Guests.csv</code></td></tr>
                  <tr><td>Source</td><td><code>AwsS3_Coral_Cloud_S3_Connection</code></td></tr>
                  <tr><td>Import from Directory</td><td><em style="opacity:0.5">Leave blank</em></td></tr>
                </tbody>
              </table>

              <div class="screenshot-gallery" style="margin-top:1rem">
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1b-add-connection-dialog.png','Add S3 Connection Dialog')"><img src="/assets/images/screenshots/ex1b-add-connection-dialog.png" alt="Add Connection dialog" loading="lazy"><div class="screenshot-caption">Add Connection Dialog</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
                <div class="screenshot-thumb" onclick="openLightbox('/assets/images/screenshots/ex1b-s3-connection-form.png','S3 Connection Form')"><img src="/assets/images/screenshots/ex1b-s3-connection-form.png" alt="S3 connection form" loading="lazy"><div class="screenshot-caption">S3 Connection Form</div><div class="screenshot-expand-icon"><i class="ph ph-magnifying-glass-plus" style="color:white;font-size:14px"></i></div></div>
              </div>

              <p style="color:var(--gray-500); font-size:0.8rem; margin:1rem 0 0.5rem;">Guest DLO → DMO Field Mappings</p>
              <table class="mapping-table">
                <thead><tr><th>DLO Field</th><th>→</th><th>Target DMO</th><th>DMO Field</th></tr></thead>
                <tbody>
                  <tr><td class="mono">Guest Id</td><td>→</td><td>Contact Point Email</td><td class="mono">Contact Point Email Id</td></tr>
                  <tr><td class="mono">Guest Id</td><td>→</td><td>Contact Point Email</td><td class="mono">Party</td></tr>
                  <tr><td class="mono">Email</td><td>→</td><td>Contact Point Email</td><td class="mono">Email Address</td></tr>
                  <tr><td class="mono">Guest Id</td><td>→</td><td>Individual</td><td class="mono">Individual Id</td></tr>
                  <tr><td class="mono">First Name</td><td>→</td><td>Individual</td><td class="mono">First Name</td></tr>
                  <tr><td class="mono">Surname</td><td>→</td><td>Individual</td><td class="mono">Last Name</td></tr>
                </tbody>
              </table>

              <!-- EXERCISE 1c: Snowflake -->
              <div class="section-divider-gold"></div>
              <div class="section-header">
                <span class="section-header__badge">Exercise 1c</span>
                <span class="section-header__title">Snowflake Zero-Copy Data Sharing</span>
              </div>
              <p style="color:var(--gray-600); font-size:0.85rem; margin-bottom:1rem;">Connect to Snowflake and ingest Hotel Reservations directly without duplicating data.</p>

              <p style="color:var(--iwc-gold-dark); font-size:0.8rem; font-weight:600; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:0.03em;">SNOWFLAKE CONNECTION CREDENTIALS</p>
              <table class="credential-table">
