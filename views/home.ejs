<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Home' }) %>
<body>
  <%- include('partials/header') %>

  <!-- ============================================== -->
  <!-- HERO SECTION                                   -->
  <!-- ============================================== -->
  <section class="hero" id="home">
    <div class="hero__bg">
      <div class="hero__shape hero__shape--1"></div>
      <div class="hero__shape hero__shape--2"></div>
      <div class="hero__shape hero__shape--3"></div>
    </div>
    <div class="hero__content container">
      <div class="hero__text">
        <div class="hero__eyebrow">
          <span class="hero__eyebrow-dot"></span>
          Salesforce + IWC Workshop
        </div>
        <h1 class="hero__title">
          Data 360 Incubation<br>
          <span class="hero__title-gradient">Workshop</span>
        </h1>
        <p class="hero__greeting" id="hero-greeting">Welcome, <%= user.name %>!</p>
        <p class="hero__subtitle">Comprehensive hands-on workshop covering Data 360, Segmentation, Identity Resolution, Calculated Insights, and Activation with a forward-looking outlook on Personalization and Agentforce capabilities.</p>
        <div class="hero__actions">
          <a href="/data360" class="btn btn--primary btn--lg">Start Workshop</a>
          <a href="/use-cases" class="btn btn--secondary btn--lg">Explore Use Cases</a>
        </div>
      </div>
      <div class="hero__mascot animate-on-scroll">
        <img src="/assets/images/astro.png" alt="Astro" class="hero__astro">
      </div>
    </div>

    <!-- Stats -->
    <div class="hero__stats container">
      <div class="stat-card animate-on-scroll">
        <div class="stat-card__number">6</div>
        <div class="stat-card__label">Deep-Dive Modules</div>
      </div>
      <div class="stat-card animate-on-scroll" data-delay="100">
        <div class="stat-card__number">25</div>
        <div class="stat-card__label">Outlook Topics</div>
      </div>
      <div class="stat-card animate-on-scroll" data-delay="200">
        <div class="stat-card__number">4h+</div>
        <div class="stat-card__label">Hands-On Content</div>
      </div>
      <div class="stat-card animate-on-scroll" data-delay="300">
        <div class="stat-card__number">AI</div>
        <div class="stat-card__label">Powered by Einstein</div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- WORKSHOP AGENDA                                -->
  <!-- ============================================== -->
  <section class="section agenda-section" id="agenda">
    <div class="container">
      <h2 class="section__title">Workshop Agenda</h2>
      <div class="agenda">
        <div class="agenda-slot">
          <div class="agenda-slot__time">10:00</div>
          <div class="agenda-slot__content">
            <h3>Introduction into Data 360</h3>
            <p>Overview of Data 360 architecture, capabilities, and the workshop scenario</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">10:30</div>
          <div class="agenda-slot__content">
            <h3>Data Ingestion &amp; Harmonization (Exercise #1)</h3>
            <p>CRM Streams, S3 Connector, field mappings, and DMO configuration</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">12:00</div>
          <div class="agenda-slot__content">
            <h3>Identity Resolution &amp; Profile Unification (Exercise #2)</h3>
            <p>Match rules, fuzzy matching, and unified profile creation</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">12:30</div>
          <div class="agenda-slot__content">
            <h3>Lunch Break</h3>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">13:30</div>
          <div class="agenda-slot__content">
            <h3>Enhance Data with Calculated Insights (Exercise #3)</h3>
            <p>SQL queries, scheduling, and KPI metric calculations</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">14:30</div>
          <div class="agenda-slot__content">
            <h3>Segmentation (Exercise #4)</h3>
            <p>Segment builder, audience filters, and publishing to targets</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">15:00</div>
          <div class="agenda-slot__content">
            <h3>What's Next?</h3>
            <p>Roadmap, advanced topics, and future workshop tracks</p>
          </div>
        </div>
        <div class="agenda-slot">
          <div class="agenda-slot__time">15:30</div>
          <div class="agenda-slot__content">
            <h3>Networking</h3>
            <p>Open discussion, Q&amp;A, and next steps</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================== -->
  <!-- IWC MOVEMENT BANNER                            -->
  <!-- ============================================== -->
  <section class="movement-banner">
    <div class="movement-banner__image-wrapper">
      <img src="/assets/images/iwc-movement-hero.jpg" alt="IWC Schaffhausen Tourbillon Movement" class="movement-banner__image" loading="lazy">
      <div class="movement-banner__overlay"></div>
    </div>
    <div class="movement-banner__content container">
      <p class="movement-banner__quote">"The inner workings define the experience"</p>
      <p class="movement-banner__caption">Precision engineering — from haute horlogerie to unified data architecture</p>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- TRACK CARDS                                    -->
  <!-- ============================================== -->
  <section class="section tracks-section" id="tracks">
    <div class="container">
      <h2 class="section__title">Workshop Tracks</h2>
      <p class="section__subtitle">Choose a track to begin your learning journey.</p>

      <div class="tracks-grid">

        <!-- Card 1: Data 360 Track -->
        <a href="/data360" class="track-card" data-track="data360" data-color="gold">
          <div class="track-card__badge track-card__badge--active">Active</div>
          <div class="track-card__icon">
            <i class="ph ph-database"></i>
          </div>
          <h3 class="track-card__title">Data 360 Track</h3>
          <p class="track-card__description">Deep-dive into Data 360</p>
          <div class="track-card__arrow">&rarr;</div>
        </a>

        <!-- Card 2: Personalization Track -->
        <a href="/personalization" class="track-card" data-track="personalization" data-color="teal">
          <div class="track-card__badge track-card__badge--soon">Coming Soon</div>
          <div class="track-card__icon">
            <i class="ph ph-user-focus"></i>
          </div>
          <h3 class="track-card__title">Personalization Track</h3>
          <p class="track-card__description">Deliver 1:1 personalized experiences</p>
          <div class="track-card__arrow">&rarr;</div>
        </a>

        <!-- Card 3: Agentforce Marketing -->
        <a href="/marketing-intelligence" class="track-card" data-track="marketing-intelligence" data-color="navy">
          <div class="track-card__badge track-card__badge--soon">Coming Soon</div>
          <div class="track-card__icon">
            <i class="ph ph-chart-line-up"></i>
          </div>
          <h3 class="track-card__title">Agentforce Marketing</h3>
          <p class="track-card__description">Campaign creation &amp; automation</p>
          <div class="track-card__arrow">&rarr;</div>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- SNEAK PEEKS                                    -->
  <!-- ============================================== -->
  <section class="section sneak-peeks-section" id="sneak-peeks">
    <div class="container">
      <h2 class="section__title">Sneak Peeks</h2>
      <p class="section__subtitle">More tracks are on the way. Here's a preview of what's coming next.</p>

      <div class="sneak-peeks-grid">

        <a href="/personalization" class="sneak-peek-card animate-on-scroll">
          <div class="sneak-peek-card__badge">Coming Soon</div>
          <div class="sneak-peek-card__lock">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0110 0v4"></path>
            </svg>
          </div>
          <h3 class="sneak-peek-card__title">Personalization Track</h3>
          <p class="sneak-peek-card__description">Deliver 1:1 personalized experiences across every touchpoint. Explore web personalization, real-time decisioning, recommenders, experience templates, and personalized customer journeys powered by Data 360.</p>
        </a>

        <a href="/marketing-intelligence" class="sneak-peek-card animate-on-scroll" data-delay="100">
          <div class="sneak-peek-card__badge">Coming Soon</div>
          <div class="sneak-peek-card__lock">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0110 0v4"></path>
            </svg>
          </div>
          <h3 class="sneak-peek-card__title">Agentforce Marketing</h3>
          <p class="sneak-peek-card__description">Build campaigns with AI agents, create forms and landing pages, configure scoring models, set up website tracking, and orchestrate marketing flows with Agentforce integration.</p>
        </a>

      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/app.js"></script>

  <% if (typeof justLoggedIn !== 'undefined' && justLoggedIn && user && user.domain === 'iwc.com') { %>
  <!-- ============================================== -->
  <!-- IWC WELCOME MODAL                              -->
  <!-- ============================================== -->
  <div class="welcome-overlay" id="welcomeOverlay">
    <div class="welcome-modal" id="welcomeModal">

      <!-- Close button -->
      <button class="welcome-modal__close" id="welcomeClose" aria-label="Close">
        <i class="ph ph-x"></i>
      </button>

      <!-- Watch assembly hero image -->
      <div class="welcome-modal__scene">
        <img src="/assets/images/iwc-assembly-hero.jpg" alt="IWC Ingenieur Assembly" class="welcome-modal__hero-image">
        <div class="welcome-modal__scene-overlay"></div>
      </div>

      <!-- Content -->
      <div class="welcome-modal__content">
        <div class="welcome-modal__iwc-badge">
          <img src="/assets/images/iwc-logo.png" alt="IWC" class="welcome-modal__iwc-logo">
        </div>

        <h2 class="welcome-modal__greeting">
          Welcome, <span class="welcome-modal__name"><%= user.name.split(' ')[0] %></span>
        </h2>

        <p class="welcome-modal__philosophy">
          <em>Probus Scafusia</em>
          <span class="welcome-modal__divider-dot">&middot;</span>
          Craftsmanship from Schaffhausen
        </p>

        <p class="welcome-modal__message">
          Just as IWC's master watchmakers combine centuries of heritage with cutting-edge innovation, today we unite the precision of <strong>Swiss engineering</strong> with the power of <strong>AI and Data 360</strong>.
        </p>
        <p class="welcome-modal__message welcome-modal__message--highlight">
          <i class="ph ph-sparkle"></i>
          Let the spirit of precision guide us as we explore <strong>Data 360</strong>, harness the power of <strong>unified customer profiles</strong>, and unlock new possibilities for IWC worldwide.
        </p>

        <div class="welcome-modal__values">
          <div class="welcome-modal__value">
            <div class="welcome-modal__value-icon"><i class="ph ph-crosshair"></i></div>
            <span>Precision</span>
          </div>
          <div class="welcome-modal__value">
            <div class="welcome-modal__value-icon"><i class="ph ph-gear-six"></i></div>
            <span>Engineering</span>
          </div>
          <div class="welcome-modal__value">
            <div class="welcome-modal__value-icon"><i class="ph ph-crown"></i></div>
            <span>Heritage</span>
          </div>
          <div class="welcome-modal__value">
            <div class="welcome-modal__value-icon"><i class="ph ph-lightning"></i></div>
            <span>Innovation</span>
          </div>
        </div>

        <button class="welcome-modal__cta" id="welcomeStart">
          <span>Begin the Journey</span>
          <i class="ph ph-arrow-right"></i>
        </button>
      </div>

    </div>
  </div>

  <style>
    .welcome-overlay {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0);
      backdrop-filter: blur(0px);
      -webkit-backdrop-filter: blur(0px);
      animation: welcomeFadeIn 0.6s ease forwards;
      padding: 1rem;
    }
    @keyframes welcomeFadeIn {
      to {
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
    }
    .welcome-modal {
      position: relative;
      width: 100%;
      max-width: 520px;
      background: linear-gradient(180deg, #0C1B2A 0%, #152238 100%);
      border: 1px solid rgba(196, 169, 98, 0.25);
      border-radius: 24px;
      overflow: hidden;
      box-shadow:
        0 40px 80px rgba(0, 0, 0, 0.6),
        0 0 60px rgba(196, 169, 98, 0.08);
      opacity: 0;
      transform: scale(0.92) translateY(20px);
      animation: welcomeModalIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    }
    @keyframes welcomeModalIn {
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .welcome-modal__close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      z-index: 10;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 50%;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.2s ease;
    }
    .welcome-modal__close:hover {
      background: rgba(196, 169, 98, 0.2);
      color: #C4A962;
    }
    .welcome-modal__scene {
      position: relative;
      width: 100%;
      height: 220px;
      overflow: hidden;
    }
    .welcome-modal__hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 60%;
      display: block;
    }
    .welcome-modal__scene-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(12, 27, 42, 0.3) 60%,
        rgba(12, 27, 42, 0.9) 100%
      );
    }
    .welcome-modal__content {
      padding: 2rem 2.5rem 2.5rem;
      text-align: center;
    }
    .welcome-modal__iwc-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 1.25rem;
      background: rgba(196, 169, 98, 0.1);
      border: 1px solid rgba(196, 169, 98, 0.25);
      border-radius: 100px;
      margin-bottom: 1.25rem;
    }
    .welcome-modal__iwc-logo {
      height: 20px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.9;
    }
    .welcome-modal__greeting {
      font-size: 1.75rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }
    .welcome-modal__name {
      background: linear-gradient(135deg, #C4A962, #E8D5A0, #C4A962);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .welcome-modal__philosophy {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 1.25rem;
      font-style: italic;
    }
    .welcome-modal__divider-dot {
      margin: 0 0.4rem;
      color: rgba(196, 169, 98, 0.5);
      font-style: normal;
    }
    .welcome-modal__message {
      font-size: 0.92rem;
      line-height: 1.65;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 0.75rem;
    }
    .welcome-modal__message strong {
      color: rgba(255, 255, 255, 0.9);
    }
    .welcome-modal__message--highlight {
      padding: 0.75rem 1rem;
      background: rgba(196, 169, 98, 0.08);
      border: 1px solid rgba(196, 169, 98, 0.15);
      border-radius: 12px;
      margin-bottom: 1.5rem;
      color: rgba(255, 255, 255, 0.7);
    }
    .welcome-modal__message--highlight i {
      color: #C4A962;
      margin-right: 0.25rem;
    }
    .welcome-modal__values {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 1.75rem;
    }
    .welcome-modal__value {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
    }
    .welcome-modal__value-icon {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(196, 169, 98, 0.1);
      border: 1px solid rgba(196, 169, 98, 0.25);
      border-radius: 12px;
      color: #C4A962;
      font-size: 1.15rem;
      transition: all 0.3s ease;
    }
    .welcome-modal__value span {
      font-size: 0.72rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .welcome-modal__cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 2rem;
      font-size: 1rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      color: #0C1B2A;
      background: linear-gradient(135deg, #C4A962 0%, #E8D5A0 50%, #A68B4B 100%);
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }
    .welcome-modal__cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .welcome-modal__cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(196, 169, 98, 0.3);
    }
    .welcome-modal__cta:hover::before { opacity: 1; }
    .welcome-modal__cta i {
      font-size: 1.1rem;
      transition: transform 0.2s ease;
    }
    .welcome-modal__cta:hover i {
      transform: translateX(3px);
    }
    .welcome-overlay--closing {
      animation: welcomeFadeOut 0.4s ease forwards;
    }
    .welcome-overlay--closing .welcome-modal {
      animation: welcomeModalOut 0.35s ease forwards;
    }
    @keyframes welcomeFadeOut {
      to { background: rgba(0, 0, 0, 0); backdrop-filter: blur(0px); -webkit-backdrop-filter: blur(0px); }
    }
    @keyframes welcomeModalOut {
      to { opacity: 0; transform: scale(0.95) translateY(-10px); }
    }
    @media (max-width: 560px) {
      .welcome-modal__content { padding: 1.5rem 1.5rem 2rem; }
      .welcome-modal__greeting { font-size: 1.4rem; }
      .welcome-modal__scene { height: 160px; }
      .welcome-modal__values { gap: 1rem; }
      .welcome-modal__value-icon { width: 36px; height: 36px; font-size: 1rem; }
      .welcome-modal__value span { font-size: 0.65rem; }
    }
  </style>

  <script>
    (function() {
      var overlay = document.getElementById('welcomeOverlay');
      var closeBtn = document.getElementById('welcomeClose');
      var startBtn = document.getElementById('welcomeStart');

      function closeWelcome() {
        overlay.classList.add('welcome-overlay--closing');
        setTimeout(function() {
          overlay.remove();
          if (window.history.replaceState) {
            window.history.replaceState({}, document.title, '/');
          }
        }, 450);
      }

      if (closeBtn) closeBtn.addEventListener('click', closeWelcome);
      if (startBtn) startBtn.addEventListener('click', closeWelcome);
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeWelcome();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && document.getElementById('welcomeOverlay')) {
          closeWelcome();
        }
      });
    })();
  </script>
  <% } %>

</body>
</html>
