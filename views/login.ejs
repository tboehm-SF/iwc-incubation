<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In | Data 360 Incubation Workshop</title>

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='12' fill='%230C1B2A'/><text x='50' y='62' text-anchor='middle' fill='%23C4A962' font-size='32' font-family='serif' font-weight='bold'>IWC</text></svg>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">

  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      background: #050d17;
    }

    /* Animated gradient mesh background - Navy/Gold IWC theme */
    .login-background {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse at 20% 50%, rgba(196, 169, 98, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(12, 27, 42, 0.8) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 80%, rgba(196, 169, 98, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 90% 80%, rgba(12, 27, 42, 0.6) 0%, transparent 50%),
        linear-gradient(135deg, #050d17 0%, #0C1B2A 50%, #050d17 100%);
      animation: meshMove 12s ease-in-out infinite alternate;
    }

    @keyframes meshMove {
      0% { background-position: 0% 0%, 100% 0%, 50% 100%, 90% 80%, 0% 0%; }
      50% { background-position: 30% 40%, 60% 10%, 60% 70%, 50% 90%, 0% 0%; }
      100% { background-position: 50% 30%, 70% 50%, 50% 60%, 60% 50%, 0% 0%; }
    }

    .login-background::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 30% 70%, rgba(196, 169, 98, 0.08) 0%, transparent 40%),
        radial-gradient(circle at 70% 30%, rgba(196, 169, 98, 0.05) 0%, transparent 40%);
      animation: meshPulse 8s ease-in-out infinite alternate;
    }

    @keyframes meshPulse {
      0% { opacity: 0.5; transform: scale(1); }
      100% { opacity: 1; transform: scale(1.05); }
    }

    /* Login card */
    .login-card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 440px;
      margin: 1rem;
      padding: 3rem 2.5rem;
      background: rgba(12, 27, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(196, 169, 98, 0.2);
      border-radius: 24px;
      box-shadow:
        0 24px 48px rgba(0, 0, 0, 0.5),
        0 0 0 1px rgba(196, 169, 98, 0.05) inset;
    }

    /* Logos */
    .login-card__logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .login-card__logo {
      height: 32px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.9;
    }

    .login-card__logo-divider {
      width: 1px;
      height: 28px;
      background: rgba(196, 169, 98, 0.3);
    }

    /* Title & subtitle */
    .login-card__title {
      text-align: center;
      font-size: 1.5rem;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.3;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }

    .login-card__subtitle {
      text-align: center;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 2rem;
      font-weight: 400;
    }

    /* Form */
    .login-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .login-form__group {
      position: relative;
    }

    .login-form__input {
      width: 100%;
      padding: 1rem 1rem 0.5rem;
      font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
      color: #ffffff;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(196, 169, 98, 0.2);
      border-radius: 12px;
      outline: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      height: 56px;
    }

    .login-form__input:focus {
      border-color: rgba(196, 169, 98, 0.6);
      background: rgba(255, 255, 255, 0.1);
      box-shadow: 0 0 0 3px rgba(196, 169, 98, 0.15);
    }

    .login-form__input::placeholder {
      color: transparent;
    }

    .login-form__label {
      position: absolute;
      top: 50%;
      left: 1rem;
      transform: translateY(-50%);
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.4);
      pointer-events: none;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      transform-origin: left center;
    }

    .login-form__input:focus ~ .login-form__label,
    .login-form__input:not(:placeholder-shown) ~ .login-form__label {
      top: 0.55rem;
      transform: translateY(0);
      font-size: 0.7rem;
      color: rgba(196, 169, 98, 0.9);
      font-weight: 500;
      letter-spacing: 0.03em;
    }

    /* Password toggle */
    .login-form__password-wrapper {
      position: relative;
    }

    .login-form__password-toggle {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.4);
      cursor: pointer;
      font-size: 1.2rem;
      padding: 0.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
    }

    .login-form__password-toggle:hover {
      color: rgba(196, 169, 98, 0.8);
    }

    /* Submit button - Gold gradient */
    .login-form__submit {
      width: 100%;
      height: 52px;
      margin-top: 0.5rem;
      font-size: 1rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      color: #0C1B2A;
      background: linear-gradient(135deg, #C4A962 0%, #A68B4B 50%, #8B7340 100%);
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      letter-spacing: 0.01em;
    }

    .login-form__submit::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .login-form__submit:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(196, 169, 98, 0.3);
    }

    .login-form__submit:hover::before {
      opacity: 1;
    }

    .login-form__submit:active {
      transform: translateY(0);
      box-shadow: 0 4px 12px rgba(196, 169, 98, 0.2);
    }

    .login-form__submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .login-form__submit--loading {
      pointer-events: none;
      color: transparent;
    }

    .login-form__submit--loading::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 22px;
      height: 22px;
      margin: -11px 0 0 -11px;
      border: 2px solid rgba(12, 27, 42, 0.3);
      border-top-color: #0C1B2A;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Error message */
    .login-form__error {
      display: none;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      color: #ff6b6b;
      background: rgba(255, 107, 107, 0.1);
      border: 1px solid rgba(255, 107, 107, 0.2);
      border-radius: 10px;
      text-align: center;
      line-height: 1.4;
    }

    .login-form__error--visible {
      display: block;
    }

    /* Footer */
    .login-card__footer {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.78rem;
      color: rgba(196, 169, 98, 0.5);
      line-height: 1.5;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .login-card {
        margin: 0.75rem;
        padding: 2rem 1.5rem;
        border-radius: 20px;
        max-width: 100%;
      }
      .login-card__title {
        font-size: 1.3rem;
      }
      .login-card__logos {
        gap: 1rem;
      }
      .login-card__logo {
        height: 26px;
      }
    }
  </style>
</head>
<body>
  <div class="login-background"></div>

  <div class="login-card">
    <div class="login-card__logos">
      <img src="/assets/images/salesforce-logo.png" alt="Salesforce" class="login-card__logo">
      <div class="login-card__logo-divider"></div>
      <img src="/assets/images/iwc-logo.png" alt="IWC Schaffhausen" class="login-card__logo">
    </div>

    <h1 class="login-card__title">Data 360<br>Incubation Workshop</h1>
    <p class="login-card__subtitle">Sign in with your corporate email</p>

    <form class="login-form" id="loginForm" autocomplete="off">
      <div class="login-form__error" id="loginError"></div>

      <div class="login-form__group">
        <input
          type="text"
          id="loginName"
          class="login-form__input"
          placeholder="Full Name"
          required
          autocomplete="name"
        >
        <label for="loginName" class="login-form__label">Full Name</label>
      </div>

      <div class="login-form__group">
        <input
          type="email"
          id="loginEmail"
          class="login-form__input"
          placeholder="Corporate Email"
          required
          autocomplete="email"
        >
        <label for="loginEmail" class="login-form__label">Corporate Email</label>
      </div>

      <div class="login-form__group login-form__password-wrapper">
        <input
          type="password"
          id="loginPassword"
          class="login-form__input"
          placeholder="Password"
          required
          autocomplete="current-password"
        >
        <label for="loginPassword" class="login-form__label">Password</label>
        <button type="button" class="login-form__password-toggle" id="passwordToggle" aria-label="Toggle password visibility">
          <i class="ph ph-eye"></i>
        </button>
      </div>

      <button type="submit" class="login-form__submit" id="loginSubmit">
        Sign In
      </button>
    </form>

    <p class="login-card__footer">Access restricted to IWC and Salesforce employees</p>
  </div>

  <script>
    (function() {
      const form = document.getElementById('loginForm');
      const nameInput = document.getElementById('loginName');
      const emailInput = document.getElementById('loginEmail');
      const passwordInput = document.getElementById('loginPassword');
      const submitBtn = document.getElementById('loginSubmit');
      const errorEl = document.getElementById('loginError');
      const passwordToggle = document.getElementById('passwordToggle');

      passwordToggle.addEventListener('click', function() {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        const icon = passwordToggle.querySelector('i');
        icon.className = isPassword ? 'ph ph-eye-slash' : 'ph ph-eye';
      });

      function showError(message) {
        errorEl.textContent = message;
        errorEl.classList.add('login-form__error--visible');
      }

      function hideError() {
        errorEl.classList.remove('login-form__error--visible');
        errorEl.textContent = '';
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        hideError();

        const name = nameInput.value.trim();
        const email = emailInput.value.trim();
        const password = passwordInput.value;

        if (!name || !email || !password) {
          showError('Please fill in all fields.');
          return;
        }

        submitBtn.classList.add('login-form__submit--loading');
        submitBtn.disabled = true;

        try {
          const response = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, password })
          });

          const data = await response.json();

          if (response.ok && data.success) {
            const domain = email.split('@')[1].toLowerCase();
            window.location.href = domain === 'iwc.com' ? '/?welcome=1' : '/';
          } else {
            showError(data.error || data.message || 'Login failed. Please check your credentials.');
          }
        } catch (err) {
          showError('Unable to connect. Please try again.');
        } finally {
          submitBtn.classList.remove('login-form__submit--loading');
          submitBtn.disabled = false;
        }
      });
    })();
  </script>
</body>
</html>
