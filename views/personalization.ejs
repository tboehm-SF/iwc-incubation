<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Personalization Track' }) %>
<body>
  <%- include('partials/header') %>

  <section class="track-hero-v2 track-hero-v2--coming-soon">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator">/</span>
        <a href="/" class="breadcrumb__link">Tracks</a>
        <span class="breadcrumb__separator">/</span>
        <span class="breadcrumb__current">Personalization</span>
      </nav>
      <div class="track-hero-v2__badge track-hero-v2__badge--soon">
        <i class="ph ph-user-focus"></i>
        Coming Soon
      </div>
      <h1 class="track-hero-v2__title">Personalization Track</h1>
      <p class="track-hero-v2__subtitle">Deliver 1:1 personalized experiences across every touchpoint using Data Cloud Personalization.</p>
    </div>
  </section>

  <section class="section coming-soon-section">
    <div class="container">
      <div class="coming-soon-card">
        <div class="coming-soon-card__icon">
          <i class="ph ph-lock-simple"></i>
        </div>
        <h2 class="coming-soon-card__title">This Track is Coming Soon</h2>
        <p class="coming-soon-card__description">The Personalization Track is currently in development. Here's a preview of what will be covered:</p>

        <div class="coming-soon-topics">
          <div class="coming-soon-topic">
            <i class="ph ph-gear-six"></i>
            <span>Setup & Configuration</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-table"></i>
            <span>Catalog & Schema</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-flow-arrow"></i>
            <span>Data Streams</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-fingerprint"></i>
            <span>Identity Resolution</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-graph"></i>
            <span>Profile Graphs</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-circles-three"></i>
            <span>Item Graphs</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-star"></i>
            <span>Recommenders</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-layout"></i>
            <span>Experience Templates</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-globe"></i>
            <span>Web Experiences</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-code"></i>
            <span>Response Templates</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-target"></i>
            <span>Personalization Points</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-chart-bar"></i>
            <span>Attribution</span>
          </div>
          <div class="coming-soon-topic">
            <i class="ph ph-map-trifold"></i>
            <span>Web Sitemap</span>
          </div>
        </div>

        <a href="/" class="btn btn--primary">Back to Home</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/app.js"></script>
</body>
</html>
