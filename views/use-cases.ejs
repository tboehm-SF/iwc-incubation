<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Use Cases' }) %>
<body>
  <%- include('partials/header') %>

  <!-- ============================================== -->
  <!-- HERO SECTION                                   -->
  <!-- ============================================== -->
  <section class="uc-hero">
    <div class="uc-hero__bg"></div>
    <div class="container">
      <nav class="uc-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="uc-hero__breadcrumb-sep">/</span>
        <span>Use Cases</span>
      </nav>
      <h1 class="uc-hero__title">Data 360 Use Cases for IWC</h1>
      <p class="uc-hero__subtitle">30 inspirational use cases across 6 topic areas &mdash; powered by Data 360, Personalization, Marketing Cloud, Einstein AI, Agentforce &amp; Service Cloud</p>
      <div class="uc-hero__counter" id="uc-counter">Showing <strong>30</strong> of <strong>30</strong> use cases</div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- FILTER BAR (sticky)                            -->
  <!-- ============================================== -->
  <div class="uc-filters" id="uc-filters">
    <div class="container">

      <!-- Search -->
      <div class="uc-filters__search">
        <i class="ph ph-magnifying-glass uc-filters__search-icon"></i>
        <input type="text" id="uc-search" class="uc-filters__search-input" placeholder="Search use cases..." autocomplete="off">
      </div>

      <!-- Cluster pills -->
      <div class="uc-filters__clusters" id="uc-cluster-filters">
        <button class="uc-filters__cluster-btn active" data-cluster="all">All</button>
        <button class="uc-filters__cluster-btn" data-cluster="1" style="--cluster-color: #C4A962">Client Intelligence</button>
        <button class="uc-filters__cluster-btn" data-cluster="2" style="--cluster-color: #0D9488">Boutique Experience</button>
        <button class="uc-filters__cluster-btn" data-cluster="3" style="--cluster-color: #3b82f6">Digital &amp; E-Commerce</button>
        <button class="uc-filters__cluster-btn" data-cluster="4" style="--cluster-color: #8b5cf6">Marketing &amp; Campaigns</button>
        <button class="uc-filters__cluster-btn" data-cluster="5" style="--cluster-color: #f59e0b">Service &amp; After-Sales</button>
        <button class="uc-filters__cluster-btn" data-cluster="6" style="--cluster-color: #10b981">Heritage &amp; Sustainability</button>
      </div>

      <!-- Technology chips -->
      <div class="uc-filters__tech" id="uc-tech-filters">
        <button class="uc-filters__tech-btn active" data-tech="all">All Tech</button>
        <button class="uc-filters__tech-btn" data-tech="Data 360" style="--tech-color: #8b5cf6">Data 360</button>
        <button class="uc-filters__tech-btn" data-tech="Personalization" style="--tech-color: #14b8a6">Personalization</button>
        <button class="uc-filters__tech-btn" data-tech="Marketing Cloud" style="--tech-color: #0176D3">Marketing Cloud</button>
        <button class="uc-filters__tech-btn" data-tech="Einstein AI" style="--tech-color: #f59e0b">Einstein AI</button>
        <button class="uc-filters__tech-btn" data-tech="Agentforce" style="--tech-color: #22c55e">Agentforce</button>
        <button class="uc-filters__tech-btn" data-tech="Service Cloud" style="--tech-color: #ef4444">Service Cloud</button>
      </div>

      <!-- Expand / Collapse toggle -->
      <div class="uc-filters__actions">
        <button class="uc-filters__toggle-btn" id="uc-expand-toggle">
          <i class="ph ph-arrows-out-simple"></i>
          <span>Expand All</span>
        </button>
      </div>

    </div>
  </div>

  <!-- ============================================== -->
  <!-- USE CASE GRID                                  -->
  <!-- ============================================== -->
  <main class="uc-main">
    <div class="container">

      <!-- ==================== -->
      <!-- CLUSTER 1: Client Intelligence -->
      <!-- ==================== -->
      <section class="uc-cluster" id="cluster-1" data-cluster-id="1">
        <div class="uc-cluster__heading" style="--cluster-color: #C4A962">
          <div class="uc-cluster__heading-icon"><i class="ph ph-user-circle-gear"></i></div>
          <div>
            <h2 class="uc-cluster__title">Client Intelligence &amp; 360&deg; Profiles</h2>
            <p class="uc-cluster__range">UC1 &ndash; UC5</p>
          </div>
        </div>
        <div class="uc-cluster__grid">

          <!-- UC1 -->
          <div class="uc-card" data-cluster="1" data-technologies="Data 360,Einstein AI" data-uc="1">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #C4A962">UC1</span>
              <h3 class="uc-card__title">Unified Collector Profile</h3>
              <button class="uc-card__expand" aria-label="Expand details"><i class="ph ph-caret-down"></i></button>
            </div>
            <div class="uc-card__tags">
              <span class="uc-card__tag" style="--tag-color: #8b5cf6">Data 360</span>
              <span class="uc-card__tag" style="--tag-color: #f59e0b">Einstein AI</span>
            </div>
            <p class="uc-card__brief">Create a single 360&deg; view of each IWC collector by unifying data from boutique POS, e-commerce, service centres, event attendance, and warranty registrations</p>
            <div class="uc-card__details">
              <div class="uc-card__benefits">
                <h4>Key Benefits</h4>
                <ul>
                  <li>Complete view of purchase history across all channels and markets</li>
                  <li>Identity resolution merging online/offline identities into one golden record</li>
                  <li>Real-time profile enrichment as new interactions occur globally</li>
                  <li>Foundation for all downstream personalisation and segmentation use cases</li>
                </ul>
              </div>
              <p class="uc-card__related">Related: UC2 (Collection Affinity), UC3 (Lifetime Value), UC11 (Boutique Clienteling)</p>
            </div>
          </div>

          <!-- UC2 -->
          <div class="uc-card" data-cluster="1" data-technologies="Data 360,Einstein AI" data-uc="2">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #C4A962">UC2</span>
              <h3 class="uc-card__title">Collection Affinity &amp; Preference Modelling</h3>
              <button class="uc-card__expand" aria-label="Expand details"><i class="ph ph-caret-down"></i></button>
            </div>
            <div class="uc-card__tags">
              <span class="uc-card__tag" style="--tag-color: #8b5cf6">Data 360</span>
              <span class="uc-card__tag" style="--tag-color: #f59e0b">Einstein AI</span>
            </div>
            <p class="uc-card__brief">Determine which IWC collections (Portugieser, Pilot&rsquo;s, Portofino, etc.) each client gravitates toward based on browsing, try-on, and purchase signals</p>
            <div class="uc-card__details">
              <div class="uc-card__benefits">
                <h4>Key Benefits</h4>
                <ul>
                  <li>AI-driven affinity scores per collection family updated in real-time</li>
                  <li>Calculated Insights combining web behaviour, boutique dwell time, and purchases</li>
                  <li>Enables hyper-relevant recommendations for new releases and limited editions</li>
                  <li>Identifies cross-collection opportunities (e.g., Pilot fan open to Ingenieur)</li>
                </ul>
              </div>
              <p class="uc-card__related">Related: UC1 (Unified Profile), UC14 (Product Recommendations), UC16 (Limited Edition Targeting)</p>
            </div>
          </div>

          <!-- UC3 -->
          <div class="uc-card" data-cluster="1" data-technologies="Data 360" data-uc="3">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #C4A962">UC3</span>
              <h3 class="uc-card__title">Collector Lifetime Value Scoring</h3>
              <button class="uc-card__expand" aria-label="Expand details"><i class="ph ph-caret-down"></i></button>
            </div>
            <div class="uc-card__tags">
              <span class="uc-card__tag" style="--tag-color: #8b5cf6">Data 360</span>
            </div>
            <p class="uc-card__brief">Compute lifetime value, purchase frequency, and next-purchase propensity using Calculated Insights across all transaction sources</p>
            <div class="uc-card__details">
              <div class="uc-card__benefits">
                <h4>Key Benefits</h4>
                <ul>
                  <li>Dynamic CLV scoring combining purchase value, frequency, and recency</li>
                  <li>Segment collectors into tiers (Platinum, Gold, Silver) for differentiated treatment</li>
                  <li>Predict next purchase timing to trigger proactive outreach</li>
                  <li>Identify rising collectors early for VIP programme consideration</li>
                </ul>
              </div>
              <p class="uc-card__related">Related: UC1 (Unified Profile), UC5 (Churn Prediction), UC20 (VIP Engagement)</p>
            </div>
          </div>

          <!-- UC4 -->
          <div class="uc-card" data-cluster="1" data-technologies="Data 360,Einstein AI" data-uc="4">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #C4A962">UC4</span>
              <h3 class="uc-card__title">Cross-Market Identity Resolution</h3>
              <button class="uc-card__expand" aria-label="Expand details"><i class="ph ph-caret-down"></i></button>
            </div>
            <div class="uc-card__tags">
              <span class="uc-card__tag" style="--tag-color: #8b5cf6">Data 360</span>
              <span class="uc-card__tag" style="--tag-color: #f59e0b">Einstein AI</span>
            </div>
            <p class="uc-card__brief">Resolve identities of collectors who shop across multiple markets (Zurich boutique, Tokyo duty-free, online) into a single unified record</p>
            <div class="uc-card__details">
              <div class="uc-card__benefits">
                <h4>Key Benefits</h4>
                <ul>
                  <li>Fuzzy and exact match rules handling multilingual name variations</li>
                  <li>Deduplication across regional CRM instances and e-commerce platforms</li>
                  <li>Accurate global headcount for board-level reporting</li>
                  <li>Prevents duplicate marketing to the same collector from different markets</li>
                </ul>
              </div>
              <p class="uc-card__related">Related: UC1 (Unified Profile), UC27 (Data Governance)</p>
            </div>
          </div>

          <!-- UC5 -->
          <div class="uc-card" data-cluster="1" data-technologies="Data 360,Einstein AI,Marketing Cloud" data-uc="5">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #C4A962">UC5</span>
              <h3 class="uc-card__title">Collector Churn Prediction &amp; Re-Engagement</h3>
              <button class="uc-card__expand" aria-label="Expand details"><i class="ph ph-caret-down"></i></button>
            </div>
            <div class="uc-card__tags">
              <span class="uc-card__tag" style="--tag-color: #8b5cf6">Data 360</span>
              <span class="uc-card__tag" style="--tag-color: #f59e0b">Einstein AI</span>
              <span class="uc-card__tag" style="--tag-color: #0176D3">Marketing Cloud</span>
            </div>
            <p class="uc-card__brief">Predict which collectors are at risk of disengagement and auto-trigger personalised re-engagement journeys before they lapse</p>
            <div class="uc-card__details">
              <div class="uc-card__benefits">
                <h4>Key Benefits</h4>
                <ul>
                  <li>Einstein-powered churn scoring based on engagement decay patterns</li>
                  <li>Automated re-engagement journeys with exclusive content or event invitations</li>
                  <li>Segment-specific retention strategies (high-CLV vs. one-time buyers)</li>
                  <li>Measurable reduction in collector dormancy rates</li>
                </ul>
              </div>
              <p class="uc-card__related">Related: UC3 (Lifetime Value), UC20 (VIP Engagement), UC17 (Journey Orchestration)</p>
            </div>
          </div>

        </div>
      </section>

      <!-- ==================== -->
      <!-- CLUSTER 2: Boutique Experience -->
      <!-- ==================== -->
      <section class="uc-cluster" id="cluster-2" data-cluster-id="2">
        <div class="uc-cluster__heading" style="--cluster-color: #0D9488">
          <div class="uc-cluster__heading-icon"><i class="ph ph-storefront"></i></div>
          <div>
            <h2 class="uc-cluster__title">Boutique Experience &amp; Clienteling</h2>
            <p class="uc-cluster__range">UC6 &ndash; UC10</p>
          </div>
        </div>
        <div class="uc-cluster__grid">

          <!-- UC6 -->
          <div class="uc-card" data-cluster="2" data-technologies="Data 360,Agentforce" data-uc="6">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #0D9488">UC6</span>
