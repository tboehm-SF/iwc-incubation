<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Use Cases' }) %>
<body>
  <%- include('partials/header') %>

  <section class="track-hero-v2">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator">/</span>
        <span class="breadcrumb__current">Use Cases</span>
      </nav>
      <div class="track-hero-v2__badge">
        <i class="ph ph-lightbulb"></i>
        IWC Schaffhausen
      </div>
      <h1 class="track-hero-v2__title">Use Cases</h1>
      <p class="track-hero-v2__subtitle">Explore how Data Cloud can transform the luxury retail experience for IWC Schaffhausen.</p>
    </div>
  </section>

  <section class="section use-cases-section">
    <div class="container">
      <div class="use-cases-grid">

        <div class="use-case-card animate-on-scroll">
          <div class="use-case-card__icon">
            <i class="ph ph-user-circle"></i>
          </div>
          <h3 class="use-case-card__title">Unified Customer Profile</h3>
          <p class="use-case-card__description">Create a single, comprehensive view of each IWC customer by unifying data from boutiques, e-commerce, service centers, events, and CRM systems. Understand the complete customer journey across all touchpoints.</p>
          <div class="use-case-card__tags">
            <span class="use-case-tag">Data Cloud</span>
            <span class="use-case-tag">Identity Resolution</span>
            <span class="use-case-tag">360 Profile</span>
          </div>
        </div>

        <div class="use-case-card animate-on-scroll" data-delay="100">
          <div class="use-case-card__icon">
            <i class="ph ph-chart-line"></i>
          </div>
          <h3 class="use-case-card__title">Behavior Tracking</h3>
          <p class="use-case-card__description">Track customer engagement across IWC's digital properties, boutique visits, and event attendance. Understand browsing patterns, collection interests, and purchase intent signals in real time.</p>
          <div class="use-case-card__tags">
            <span class="use-case-tag">Web Analytics</span>
            <span class="use-case-tag">Event Tracking</span>
            <span class="use-case-tag">Real-Time</span>
          </div>
        </div>

        <div class="use-case-card animate-on-scroll" data-delay="200">
          <div class="use-case-card__icon">
            <i class="ph ph-ranking"></i>
          </div>
          <h3 class="use-case-card__title">Lead Scoring</h3>
          <p class="use-case-card__description">Use calculated insights and AI to score prospects based on engagement, purchase history, and behavioral signals. Prioritize high-value prospects for boutique outreach and exclusive event invitations.</p>
          <div class="use-case-card__tags">
            <span class="use-case-tag">Einstein AI</span>
            <span class="use-case-tag">Calculated Insights</span>
            <span class="use-case-tag">Scoring</span>
          </div>
        </div>

        <div class="use-case-card animate-on-scroll" data-delay="300">
          <div class="use-case-card__icon">
            <i class="ph ph-user-focus"></i>
          </div>
          <h3 class="use-case-card__title">Web Personalization</h3>
          <p class="use-case-card__description">Deliver personalized content on iwc.com based on customer preferences, browsing history, and collection interests. Show relevant watch recommendations, stories, and boutique information.</p>
          <div class="use-case-card__tags">
            <span class="use-case-tag">Personalization</span>
            <span class="use-case-tag">Recommenders</span>
            <span class="use-case-tag">Real-Time</span>
          </div>
        </div>

        <div class="use-case-card animate-on-scroll" data-delay="400">
          <div class="use-case-card__icon">
            <i class="ph ph-users-three"></i>
          </div>
          <h3 class="use-case-card__title">Segmentation &amp; Activation</h3>
          <p class="use-case-card__description">Build sophisticated audience segments based on purchase value, collection affinity, service history, and engagement patterns. Activate segments across email, advertising, and boutique outreach channels.</p>
          <div class="use-case-card__tags">
            <span class="use-case-tag">Segments</span>
            <span class="use-case-tag">Activation</span>
            <span class="use-case-tag">Multi-Channel</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/app.js"></script>
</body>
</html>
