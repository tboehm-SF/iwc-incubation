            <p class="uc-cluster__range">UC11 &ndash; UC15</p>
          </div>
        </div>
        <div class="uc-cluster__grid">

          <!-- UC11 -->
          <div class="uc-card" data-cluster="3" data-technologies="Data 360,Personalization" data-uc="11">
            <div class="uc-card__header">
              <span class="uc-card__badge" style="--cluster-color: #3b82f6">UC11</span>
