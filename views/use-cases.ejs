      <!-- ==================== -->
      <!-- CLUSTER 3: Digital & E-Commerce -->
      <!-- ==================== -->
      <section class="uc-cluster" id="cluster-3" data-cluster-id="3">
        <div class="uc-cluster__heading" style="--cluster-color: #3b82f6">
          <div class="uc-cluster__heading-icon"><i class="ph ph-globe-hemisphere-west"></i></div>
          <div>
